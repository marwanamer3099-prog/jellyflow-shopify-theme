{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Experience the JellyFlow Lamp"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Calm your space with soothing jellyfish movement."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ]
}
{% endschema %}

<section class="hero-section" style="text-align:center; padding:3rem 1rem;">
  {% if section.settings.hero_image != blank %}
    <img src="{{ section.settings.hero_image | img_url: '800x' }}" 
         alt="Hero image" 
         style="max-width:100%; height:auto; margin-bottom:1.5rem;" />
  {% endif %}
  <h1 style="font-size:2.5rem;">{{ section.settings.heading }}</h1>
  <p style="font-size:1.3rem; margin:1rem 0 2rem;">{{ section.settings.subheading }}</p>
  <a href="{{ section.settings.cta_link }}" 
     style="background:#0072f5; color:#fff; padding:0.85rem 1.5rem; border-radius:8px; font-weight:600; text-decoration:none;">
    {{ section.settings.cta_text }}
  </a>
</section>
